# ─────────────────────────────────────────────────────────────
# AI Art Arena — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Auth (NextAuth v5) ────────────────────────────────────────
# Full URL of your deployment (no trailing slash)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# 32+ character random secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth app — github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Supabase ──────────────────────────────────────────────────
# Found at: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (rate limiting) ─────────────────────────────
# Found at: console.upstash.com → database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Hashing salts ─────────────────────────────────────────────
# Used to hash IPs and emails before storage — NEVER change in production
# once votes exist (changing breaks dedup). Generate: openssl rand -hex 32
IP_HASH_SALT=
VOTE_HASH_SALT=

# ── Email (Resend) ────────────────────────────────────────────
# Found at: resend.com → API Keys
RESEND_API_KEY=

# Admin email — receives vote reminders and system notifications
# REQUIRED: Inngest will throw at startup if this is unset
ADMIN_EMAIL=your@email.com

# ── Inngest (background jobs) ─────────────────────────────────
# Found at: app.inngest.com → your app → keys
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ── Sentry (error tracking) ───────────────────────────────────
# Found at: sentry.io → project → Settings → Client Keys
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Required for source map uploads during CI/production builds
# Found at: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# ── Logging ───────────────────────────────────────────────────
# Levels: trace | debug | info | warn | error | silent
LOG_LEVEL=info
