# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://olliedoesis.dev

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
AUTH_URL=http://localhost:3000
AUTH_SECRET=

# GitHub OAuth app — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Security ──────────────────────────────────────────────────────────────────
# Random 32+ character string — used to hash IPs before storage
IP_HASH_SALT=

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# API key from resend.com — needed for magic links and comment notifications
RESEND_API_KEY=
# Admin email address — receives comment notification emails
ADMIN_EMAIL=

# ── Background jobs (Inngest) ─────────────────────────────────────────────────
# Keys from app.inngest.com — needed for contest automation
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
